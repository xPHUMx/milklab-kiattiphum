# Copy this file to .env (DO NOT commit .env)
# Get keys at the URLs in the comments

# Gemini API (S1, S2, S3, S4)
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIzaSy...your-key-here

# Telegram Bot (S2 option A)
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# LINE Messaging API (S2 option B)
# https://developers.line.biz/console/
LINE_CHANNEL_TOKEN=
LINE_CHANNEL_SECRET=

# Google Sheets API (S2)
# Get service account JSON, paste contents here as single line
# https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_SHEETS_CREDENTIALS=

# HuggingFace (S3 deploy)
# https://huggingface.co/settings/tokens
HF_TOKEN=
